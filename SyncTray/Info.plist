<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>SyncTray</string>
	<key>CFBundleIdentifier</key>
	<string>com.synctray.app</string>
	<key>CFBundleName</key>
	<string>SyncTray</string>
	<key>CFBundleShortVersionString</key>
	<string>0.34.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>Dash0AuthToken</key>
	<string>$(DASH0_AUTH_TOKEN)</string>
	<!-- Seed value only; the real short SHA is written by the "Embed Git Commit
	     SHA" Xcode build phase. GIT_COMMIT_SHA is an undefined build setting, so
	     this resolves to an empty string at build time (TelemetryService then
	     falls back to <marketing>+<build>). -->
	<key>GitCommitSHA</key>
	<string>$(GIT_COMMIT_SHA)</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<key>LSUIElement</key>
	<true/>
	<key>NSUserNotificationAlertStyle</key>
	<string>banner</string>
	<key>OTelExporterEndpoint</key>
	<string>$(OTEL_EXPORTER_OTLP_ENDPOINT)</string>
</dict>
</plist>
