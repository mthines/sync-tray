# OpenTelemetry Configuration
# Copy this file to ~/.config/synctray/.env and fill in your values.
# The app reads this file at runtime regardless of how it is launched.

# Service identity (same in every environment)
OTEL_SERVICE_NAME=synctray

# Resource attributes (comma-separated key=value pairs)
# deployment.environment.name should change per environment (development, staging, production)
OTEL_RESOURCE_ATTRIBUTES=service.namespace=synctray,deployment.environment.name=development

# OTLP exporter endpoint (base URL — /v1/traces and /v1/metrics are appended automatically)
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingress.europe-west4.gcp.dash0-dev.com

# OTLP exporter auth headers (comma-separated Key=Value pairs)
# Create a Dash0 auth token at: Settings → Auth Tokens → Create Token (Ingesting permission)
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <your-dash0-auth-token>

# Convenience alternative: set just the token (used if OTEL_EXPORTER_OTLP_HEADERS is not set)
# DASH0_AUTH_TOKEN=<your-dash0-auth-token>
